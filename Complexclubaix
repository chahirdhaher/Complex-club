<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Complex Club — Aix en Provence</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --pink: #ff1a8c;
    --pink-glow: #ff1a8c;
    --pink-soft: #ff69b4;
    --black: #000000;
    --dark: #0a0a0a;
    --card: #111111;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* BACKGROUND GRAIN */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 20px;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(255,26,140,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(255,26,140,0.015) 3px,
      rgba(255,26,140,0.015) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .hero-content { position: relative; z-index: 2; }

  .logo-wrap {
    width: 200px;
    height: 200px;
    margin: 0 auto 30px;
    animation: pulse-logo 3s ease-in-out infinite;
    filter: drop-shadow(0 0 30px rgba(255,26,140,0.8));
  }

  .logo-wrap img { width: 100%; height: 100%; object-fit: contain; }

  @keyframes pulse-logo {
    0%, 100% { filter: drop-shadow(0 0 25px rgba(255,26,140,0.7)); }
    50% { filter: drop-shadow(0 0 50px rgba(255,26,140,1)) drop-shadow(0 0 80px rgba(255,26,140,0.4)); }
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(60px, 12vw, 130px);
    letter-spacing: 0.08em;
    color: #fff;
    line-height: 0.9;
    text-shadow: 0 0 40px rgba(255,26,140,0.5);
    animation: fadeUp 1s ease both;
  }

  .hero-sub {
    font-size: clamp(10px, 2vw, 13px);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--pink);
    margin-top: 10px;
    font-weight: 600;
    animation: fadeUp 1s 0.2s ease both;
  }

  .hero-tagline {
    margin-top: 20px;
    font-size: clamp(12px, 1.8vw, 15px);
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 300;
    animation: fadeUp 1s 0.4s ease both;
  }

  .scroll-cta {
    margin-top: 50px;
    display: inline-block;
    padding: 14px 40px;
    border: 1px solid var(--pink);
    color: var(--pink);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: 700;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
    animation: fadeUp 1s 0.6s ease both;
  }

  .scroll-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--pink);
    transform: translateX(-101%);
    transition: transform 0.3s ease;
    z-index: -1;
  }

  .scroll-cta:hover { color: #000; }
  .scroll-cta:hover::before { transform: translateX(0); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* DIVIDER */
  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--pink), transparent);
    position: relative;
  }

  /* RESERVATION SECTION */
  .reservation {
    padding: 80px 20px 100px;
    position: relative;
    z-index: 2;
  }

  .section-label {
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.4em;
    color: var(--pink);
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .section-title {
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(38px, 7vw, 72px);
    letter-spacing: 0.06em;
    color: #fff;
    margin-bottom: 60px;
    text-shadow: 0 0 30px rgba(255,26,140,0.3);
  }

  .form-card {
    max-width: 580px;
    margin: 0 auto;
    background: var(--card);
    border: 1px solid rgba(255,26,140,0.2);
    padding: 50px 40px;
    position: relative;
    box-shadow: 0 0 60px rgba(255,26,140,0.07), inset 0 0 40px rgba(0,0,0,0.5);
  }

  .form-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--pink), transparent);
  }

  .form-row { margin-bottom: 28px; }

  .form-label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 10px;
    font-weight: 600;
  }

  .form-input, .form-select {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,26,140,0.2);
    color: #fff;
    padding: 14px 18px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s, box-shadow 0.3s;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-input:focus, .form-select:focus {
    border-color: var(--pink);
    box-shadow: 0 0 20px rgba(255,26,140,0.15);
  }

  .form-input::placeholder { color: rgba(255,255,255,0.2); }

  .select-wrap { position: relative; }

  .select-wrap::after {
    content: '▾';
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--pink);
    pointer-events: none;
    font-size: 16px;
  }

  .form-select option { background: #111; color: #fff; }

  /* TYPE TOGGLE */
  .type-toggle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .type-btn {
    padding: 14px 10px;
    border: 1px solid rgba(255,26,140,0.25);
    background: transparent;
    color: rgba(255,255,255,0.5);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .type-btn.active {
    border-color: var(--pink);
    color: var(--pink);
    box-shadow: 0 0 20px rgba(255,26,140,0.2);
    background: rgba(255,26,140,0.08);
  }

  .type-btn:hover:not(.active) {
    border-color: rgba(255,26,140,0.5);
    color: rgba(255,255,255,0.7);
  }

  .type-btn .icon { display: block; font-size: 20px; margin-bottom: 6px; }

  /* SUBMIT */
  .btn-submit {
    width: 100%;
    padding: 18px;
    background: var(--pink);
    border: none;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 10px;
    position: relative;
    overflow: hidden;
  }

  .btn-submit:hover {
    background: #fff;
    box-shadow: 0 0 30px rgba(255,26,140,0.6);
  }

  .btn-submit:active { transform: scale(0.99); }

  /* SUCCESS */
  .success-msg {
    display: none;
    text-align: center;
    padding: 30px;
    animation: fadeUp 0.5s ease;
  }

  .success-msg .check {
    font-size: 48px;
    filter: drop-shadow(0 0 20px rgba(255,26,140,0.8));
    margin-bottom: 16px;
  }

  .success-msg h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.1em;
    color: var(--pink);
    margin-bottom: 8px;
  }

  .success-msg p {
    color: rgba(255,255,255,0.5);
    font-size: 13px;
    letter-spacing: 0.1em;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid rgba(255,26,140,0.15);
    padding: 40px 20px;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .footer-logo {
    width: 60px;
    margin: 0 auto 16px;
    opacity: 0.6;
    filter: drop-shadow(0 0 10px rgba(255,26,140,0.4));
  }

  footer p {
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* FLOATING PARTICLES */
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: var(--pink);
    border-radius: 50%;
    animation: float linear infinite;
    opacity: 0;
  }

  @keyframes float {
    0% { transform: translateY(100vh) translateX(0); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-10vh) translateX(40px); opacity: 0; }
  }

  @media (max-width: 600px) {
    .form-card { padding: 35px 22px; }
  }
</style>
</head>
<body>

<!-- Particles -->
<div class="particles" id="particles"></div>

<!-- HERO -->
<section class="hero">
  <div class="scanlines"></div>
  <div class="hero-content">
    <div class="logo-wrap">
      <img src="data:image/jpeg;base64," alt="Complex Club Logo">
    </div>
    <h1 class="hero-title">COMPLEX</h1>
    <p class="hero-sub">Club · Aix en Provence</p>
    <p class="hero-tagline">Vendredi &amp; Samedi · Ouverture 23h</p>
    <a href="#reservation" class="scroll-cta">Réserver maintenant</a>
  </div>
</section>

<div class="divider"></div>

<!-- RESERVATION -->
<section class="reservation" id="reservation">
  <p class="section-label">Accès &amp; Tables</p>
  <h2 class="section-title">RÉSERVATION</h2>

  <div class="form-card">
    <div id="form-content">
      <!-- Nom -->
      <div class="form-row">
        <label class="form-label" for="nom">Votre nom</label>
        <input class="form-input" type="text" id="nom" placeholder="Prénom Nom" autocomplete="off">
      </div>

      <!-- Soir -->
      <div class="form-row">
        <label class="form-label">Soirée</label>
        <div class="select-wrap">
          <select class="form-select" id="soir">
            <option value="" disabled selected>Choisir une date</option>
            <option value="vendredi">Vendredi</option>
            <option value="samedi">Samedi</option>
          </select>
        </div>
      </div>

      <!-- Personnes -->
      <div class="form-row">
        <label class="form-label" for="personnes">Nombre de personnes</label>
        <div class="select-wrap">
          <select class="form-select" id="personnes">
            <option value="" disabled selected>Sélectionner</option>
            <option value="1">1 personne</option>
            <option value="2">2 personnes</option>
            <option value="3">3 personnes</option>
            <option value="4">4 personnes</option>
            <option value="5">5 personnes</option>
            <option value="6">6 personnes</option>
            <option value="7+">7 personnes et +</option>
          </select>
        </div>
      </div>

      <!-- Type -->
      <div class="form-row">
        <label class="form-label">Type d'accès</label>
        <div class="type-toggle">
          <button class="type-btn active" onclick="selectType(this, 'entree')" type="button">
            <span class="icon">🎟️</span>
            Entrée Simple
          </button>
          <button class="type-btn" onclick="selectType(this, 'table')" type="button">
            <span class="icon">🥂</span>
            Table VIP
          </button>
        </div>
      </div>

      <input type="hidden" id="type-access" value="entree">

      <button class="btn-submit" onclick="submitForm()">VALIDER MA RÉSERVATION</button>
    </div>

    <div class="success-msg" id="success-msg">
      <div class="check">💗</div>
      <h3>Réservation confirmée !</h3>
      <p id="success-detail"></p>
      <p style="margin-top:12px;">À très vite au Complex ✨</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <img class="footer-logo" src="data:image/jpeg;base64," alt="Complex">
  <p>© 2025 Complex Club · Aix en Provence</p>
  <p style="margin-top:6px;">Ouvert Vendredi &amp; Samedi dès 23h</p>
</footer>

<script>
  // Particles
  const container = document.getElementById('particles');
  for (let i = 0; i < 25; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.left = Math.random() * 100 + 'vw';
    p.style.animationDuration = (8 + Math.random() * 14) + 's';
    p.style.animationDelay = (Math.random() * 12) + 's';
    p.style.width = p.style.height = (Math.random() > 0.7 ? 3 : 2) + 'px';
    container.appendChild(p);
  }

  // Type selection
  function selectType(btn, val) {
    document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('type-access').value = val;
  }

  // Submit
  function submitForm() {
    const nom = document.getElementById('nom').value.trim();
    const soir = document.getElementById('soir').value;
    const personnes = document.getElementById('personnes').value;
    const type = document.getElementById('type-access').value;

    if (!nom || !soir || !personnes) {
      shakeCard();
      return;
    }

    document.getElementById('form-content').style.display = 'none';
    const msg = document.getElementById('success-msg');
    msg.style.display = 'block';

    const typeLabel = type === 'table' ? 'Table VIP' : 'Entrée Simple';
    const soirLabel = soir.charAt(0).toUpperCase() + soir.slice(1);
    document.getElementById('success-detail').textContent =
      nom + ' — ' + soirLabel + ' · ' + personnes + ' pers. · ' + typeLabel;
  }

  function shakeCard() {
    const card = document.querySelector('.form-card');
    card.style.animation = 'shake 0.4s ease';
    setTimeout(() => card.style.animation = '', 400);
  }

  const style = document.createElement('style');
  style.textContent = '@keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-8px)} 60%{transform:translateX(8px)} 80%{transform:translateX(-4px)} }';
  document.head.appendChild(style);
</script>
</body>
</html>
